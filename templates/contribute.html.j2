// Generate BibTeX and write it into that card's own textarea (replacing, not appending)
function refToBibtex(i) {
  const key   = val(`rk-${i}`);
  const title = val(`rt-${i}`);
  if (!key)   { markError(document.getElementById(`rk-${i}`), null); return; }
  if (!title) { markError(document.getElementById(`rt-${i}`), null); return; }

  const authors = val(`ra-${i}`);
  const venue   = val(`rv-${i}`);

  const yearM = venue.match(/\b(19|20)\d{2}\b/);
  const year  = yearM ? yearM[0] : 'YYYY';

  const isJournal = /\bjournal\b|JAIR|AIJ|\bArtificial Intelligence\b/i.test(venue);
  const isThesis  = /\bthesis\b|\bPhD\b|\bdissertation\b/i.test(venue);
  const type = isThesis ? 'phdthesis' : (isJournal ? 'article' : 'inproceedings');

  const authFmt = authors.replace(/,\s+(?=[A-Z])/g, ' and ');

  let entry = `@${type}{${key},\n`;
  entry += `  title     = {${title}},\n`;
  if (authors) entry += `  author    = {${authFmt}},\n`;
  if (type === 'phdthesis')       entry += `  school    = {${venue.split(',')[0] || 'TODO'}},\n`;
  else if (type === 'article')    entry += `  journal   = {${venue.split(',')[0] || 'TODO'}},\n`;
  else                            entry += `  booktitle = {${venue.split(',')[0] || 'TODO'}},\n`;
  entry += `  year      = {${year}},\n}`;

  document.getElementById(`rb-${i}`).value = entry;

  const btn = document.getElementById(`bib-btn-${i}`);
  btn.textContent = '✓ Generated';
  btn.style.borderColor = 'var(--accent)'; btn.style.color = 'var(--accent)';
  setTimeout(() => {
    btn.textContent = '→ Generate BibTeX';
    btn.style.borderColor = ''; btn.style.color = '';
  }, 1800);
}

// ── Markdown generators ───────────────────────────────────────────────────────
function yamlList(arr) {
  return arr.length === 0 ? '[]' : '[' + arr.map(v => JSON.stringify(v)).join(', ') + ']';
}

function genGeneral() {
  const slug       = val('f-slug') || 'slug';
  const title      = val('f-title') || 'Untitled';
  const subtitle   = val('f-subtitle');
  const catSel     = document.getElementById('f-category').value;
  const category   = catSel === 'Other' ? (val('f-cat-other') || 'Other') : catSel;
  const originYear = val('f-origin-year');
  const origin     = val('f-origin');
  const proposers  = val('f-proposers').split(',').map(s => s.trim()).filter(Boolean);
  const tags       = checked('tags-grid');
  const langs      = checked('lang-grid');
  const ipc        = checked('ipc-grid');
  const desc       = val('f-desc');
  const history    = val('f-history');
  const variants   = getVariants();
  const complexity = getComplexity();
  const today      = new Date().toISOString().slice(0, 10);

  let o = `---\nslug: ${slug}\ntitle: ${title}\n`;
  if (subtitle)   o += `subtitle: ${JSON.stringify(subtitle)}\n`;
  o += `proposers: ${yamlList(proposers)}\n`;
  if (origin)     o += `origin: ${JSON.stringify(origin)}\n`;
  if (originYear) o += `origin_year: ${originYear}\n`;
  o += `last_updated: "${today}"\ncategory: ${category}\n`;
  o += `tags: ${yamlList(tags)}\nlanguages: ${yamlList(langs)}\nipc_editions: ${yamlList(ipc)}\n---\n\n`;
  o += `## Description\n\n${desc || '<!-- TODO -->'}\n\n`;
  if (history) o += `## History\n\n${history}\n\n`;
  if (variants.length) {
    o += `## Variants\n\n`;
    variants.forEach(v => { o += v.href ? `- [${v.label}](${v.href})\n` : `- ${v.label}\n`; });
    o += '\n';
  }
  if (complexity.length) {
    o += `## Complexity\n\n| Problem | Qualifier | Result | Class |\n|---|---|---|---|\n`;
    complexity.forEach(r => { o += `| ${r.problem} | ${r.qualifier} | ${r.result} | ${r.cls} |\n`; });
    o += '\n';
  }
  return o.trimEnd() + '\n';
}

function genReferences() {
  const refs = getRefs();
  if (!refs.length) return null;

  let o = `## References\n\n`;
  refs.forEach(r => {
    o += `[${r.key}]: ${r.title}\n`;
    if (r.authors) o += `authors: ${r.authors}\n`;
    if (r.venue)   o += `venue: ${r.venue}\n`;
    if (r.url)     o += `url: ${r.url}\n`;
    if (r.note)    o += `note: ${r.note}\n`;
    o += '\n';
  });

  const bibtexEntries = refs.map(r => r.bibtex).filter(Boolean);
  if (bibtexEntries.length) {
    o += `## BibTeX\n\n\`\`\`bibtex\n${bibtexEntries.join('\n\n')}\n\`\`\`\n`;
  }
  return o.trimEnd() + '\n';
}

function genDomain(d) {
  let o = `---\ntitle: ${JSON.stringify(d.title || 'Untitled')}\nlanguage: ${d.lang}\n`;
  if (d.src)   o += `source: ${d.src}\n`;
  if (d.notes) o += `notes: ${JSON.stringify(d.notes)}\n`;
  o += `---\n\n`;
  if (d.ss) o += `## State Space\n\n${d.ss}\n\n`;
  if (d.types && d.types.length) {
    o += `## Types\n\n| name | parent |\n|---|---|\n`;
    d.types.forEach(t => { o += `| ${t.name} | ${t.parent || 'object'} |\n`; });
    o += '\n';
  }
  if (d.objects && d.objects.length) {
    o += `## Objects\n\n| name | type |\n|---|---|\n`;
    d.objects.forEach(obj => { o += `| ${obj.name} | ${obj.type || ''} |\n`; });
    o += '\n';
  }
  o += `## Predicates\n\n| name | desc |\n|---|---|\n`;
  if (d.predicates && d.predicates.length) {
    d.predicates.forEach(p => { o += `| ${p.name} | ${p.desc || ''} |\n`; });
  } else {
    o += `| pred(?x) | <!-- TODO --> |\n`;
  }
  o += '\n';
  if (d.actions && d.actions.length) {
    o += `## Actions\n\n`;
    d.actions.forEach(a => {
      o += `#### ${a.name}${a.desc ? ' — ' + a.desc : ''}\n`;
      const pre = a.preconditions || 'TODO';
      const add = a.add_effects   || 'TODO';
      const del = a.del_effects   || 'TODO';
      o += `\`\`\`\npreconditions: ${pre}\nadd effects:   ${add}\ndel effects:   ${del}\n\`\`\`\n\n`;
    });
  } else {
    o += `## Actions\n\n#### action(?x - type) — TODO: short description\n\`\`\`\npreconditions: TODO\nadd effects:   TODO\ndel effects:   TODO\n\`\`\`\n\n`;
  }
  o += d.goal ? `## Goal\n\n${d.goal}\n\n` : `## Goal\n\nTODO: describe the goal condition.\n\n`;
  o += `## Instances\n\n| name | n | k* | status | source | file |\n|---|---|---|---|---|---|\n`;
  if (d.instances && d.instances.length) {
    d.instances.forEach(inst => {
      o += `| ${inst.name || 'instance-01'} | ${inst.n || '—'} | ${inst.k || '—'} | ${inst.status || 'unknown'} | ${inst.source || ''} | ${inst.file || ''} |\n`;
    });
  } else {
    o += `| instance-01 | — | — | unknown | | instances/instance-01.pddl |\n`;
  }
  return o.trimEnd() + '\n';
}

// ── Render output ─────────────────────────────────────────────────────────────
function renderOutput() {
  const slug = val('f-slug') || 'slug';
  document.getElementById('folder-hint').textContent = `problems/probNNN-${slug}/`;

  const area = document.getElementById('output-area');
  area.innerHTML = '';

  function mkBlock(path, content) {
    const b = document.createElement('div');
    b.className = 'out-file';
    b.innerHTML = `
      <div class="out-hdr">
        <span class="out-path">${esc(path)}</span>
        <button class="dl-btn" onclick="dlText('${esc(path.split('/').pop())}', this.closest('.out-file').querySelector('pre').textContent)">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M5 1v5M2.5 4.5L5 7l2.5-2.5M1 8.5h8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
          Download
        </button>
      </div>
      <pre class="out-pre">${esc(content)}</pre>`;
    area.appendChild(b);
  }

  mkBlock('general.md', genGeneral());
  const refsMd = genReferences();
  if (refsMd) mkBlock('references.md', refsMd);
  getDomains().forEach(d => mkBlock(`domains/${d.key}/domain.md`, genDomain(d)));

  if (!area.children.length)
    area.innerHTML = '<p style="color:var(--muted);font-size:13px">Fill in at least a title and one domain, then click Regenerate.</p>';
}

// ── ZIP download ──────────────────────────────────────────────────────────────
async function downloadZip() {
  const blocks = document.querySelectorAll('#output-area .out-file');
  if (!blocks.length) { renderOutput(); return; }

  const zip = new JSZip();
  blocks.forEach(b => {
    zip.file(
      b.querySelector('.out-path').textContent.trim(),
      b.querySelector('pre').textContent
    );
  });

  const blob = await zip.generateAsync({ type: 'blob' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `${val('f-slug') || 'problem'}.zip`;
  a.click();
  URL.revokeObjectURL(a.href);
}

// ── Utilities ─────────────────────────────────────────────────────────────────
function val(id) { const el = document.getElementById(id); return el ? el.value.trim() : ''; }
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function dlText(filename, content) {
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([content], { type: 'text/plain' }));
  a.download = filename; a.click(); URL.revokeObjectURL(a.href);
}

document.addEventListener('DOMContentLoaded', () => { addDomain(); });
</script>
</body>
</html>
