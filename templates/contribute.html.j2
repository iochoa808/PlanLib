             venue: val(`rv-${i}`), url: val(`ru-${i}`), note: val(`rn-${i}`),
             bibtex: val(`rb-${i}`) };
  }).filter(r => r.key);
}

// Generate BibTeX and write it into that card's own textarea (replacing, not appending)
function refToBibtex(i) {
  const key   = val(`rk-${i}`);
  const title = val(`rt-${i}`);
  if (!key)   { markError(document.getElementById(`rk-${i}`), null); return; }
  if (!title) { markError(document.getElementById(`rt-${i}`), null); return; }

  const authors = val(`ra-${i}`);
  const venue   = val(`rv-${i}`);

  const yearM = venue.match(/\b(19|20)\d{2}\b/);
  const year  = yearM ? yearM[0] : 'YYYY';

  const isJournal = /\bjournal\b|JAIR|AIJ|\bArtificial Intelligence\b/i.test(venue);
  const isThesis  = /\bthesis\b|\bPhD\b|\bdissertation\b/i.test(venue);
  const type = isThesis ? 'phdthesis' : (isJournal ? 'article' : 'inproceedings');

  const authFmt = authors.replace(/,\s+(?=[A-Z])/g, ' and ');

  let entry = `@${type}{${key},\n`;
  entry += `  title     = {${title}},\n`;
  if (authors) entry += `  author    = {${authFmt}},\n`;
  if (type === 'phdthesis')       entry += `  school    = {${venue.split(',')[0] || 'TODO'}},\n`;
  else if (type === 'article')    entry += `  journal   = {${venue.split(',')[0] || 'TODO'}},\n`;
  else                            entry += `  booktitle = {${venue.split(',')[0] || 'TODO'}},\n`;
  entry += `  year      = {${year}},\n}`;

  document.getElementById(`rb-${i}`).value = entry;

  const btn = document.getElementById(`bib-btn-${i}`);
  btn.textContent = '✓ Generated';
  btn.style.borderColor = 'var(--accent)'; btn.style.color = 'var(--accent)';
  setTimeout(() => {
    btn.textContent = '→ Generate BibTeX';
    btn.style.borderColor = ''; btn.style.color = '';
  }, 1800);
}

// ── Load existing problem ─────────────────────────────────────────────────────
function clearForm() {
  ['f-title','f-slug','f-subtitle','f-origin','f-origin-year','f-proposers'].forEach(id => {
    const el = document.getElementById(id); if (el) el.value = '';
  });
  const catOther = document.getElementById('f-cat-other');
  if (catOther) catOther.style.display = 'none';
  const catSel = document.getElementById('f-category');
  if (catSel) catSel.value = 'Classical';
  ['tags-grid','lang-grid','ipc-grid'].forEach(id => {
    document.querySelectorAll(`#${id} input[type=checkbox]`).forEach(c => c.checked = false);
  });
  document.getElementById('f-desc').value = '';
  document.getElementById('f-history').value = '';
  document.getElementById('variants-list').innerHTML = '';
  document.getElementById('complexity-list').innerHTML = '';
  document.getElementById('domains-list').innerHTML = '';
  document.getElementById('refs-list').innerHTML = '';
  vi = 0; cxi = 0; di = 0; ii = 0; tyi = 0; pi = 0; ppi = 0; aci = 0; api_i = 0; ri = 0;
  domainFiles.clear();
  instanceFiles.clear();
}

function loadSelectedProblem() {
  const sel = document.getElementById('load-prob-sel');
  if (!sel) return;
  if (sel.value === '') { clearForm(); addDomain(); return; }
  loadProblem(parseInt(sel.value));
  const msg = document.getElementById('load-ok');
  if (msg) { msg.style.display = ''; setTimeout(() => msg.style.display = 'none', 3000); }
}

function loadProblem(probIdx) {
  const d = PLANLIB_PROBLEMS[probIdx];
  if (!d) return;
  clearForm();
  const sv = (id, v) => { const el = document.getElementById(id); if (el) el.value = v || ''; };

  // Step 0 — Identity
  sv('f-title', d.title); sv('f-slug', d.slug); sv('f-subtitle', d.subtitle);
  sv('f-origin', d.origin); sv('f-origin-year', d.origin_year); sv('f-proposers', d.proposers);
  const catSel = document.getElementById('f-category');
  if (catSel) {
    if ([...catSel.options].some(o => o.value === d.category)) catSel.value = d.category;
    else { catSel.value = 'Other'; sv('f-cat-other', d.category); document.getElementById('f-cat-other').style.display = ''; }
  }

  // Step 1 — Tags / Languages / IPC
  const setChecks = (gridId, vals) => {
    const set = new Set(vals || []);
    document.querySelectorAll(`#${gridId} input[type=checkbox]`).forEach(c => {
      if (set.has(c.value)) { c.checked = true; set.delete(c.value); }
    });
    set.forEach(v => {
      const lbl = document.createElement('label'); lbl.className = 'ci';
      lbl.innerHTML = `<input type="checkbox" value="${esc(v)}" checked><span>${esc(v)}</span>`;
      document.getElementById(gridId).appendChild(lbl);
    });
  };
  setChecks('tags-grid', d.tags); setChecks('lang-grid', d.languages); setChecks('ipc-grid', d.ipc_editions);

  // Step 2 — Description & History
  sv('f-desc', d.description); sv('f-history', d.history);

  // Step 3 — Variants (hrefs applied after domains are added below)
  (d.variants || []).forEach(v => {
    addVariant();
    const rows = [...document.querySelectorAll('#variants-list .drow')];
    const lI = rows[rows.length - 1]?.id.replace('var-', '');
    if (lI != null) sv(`vl-${lI}`, v.label);
  });

  // Step 3 — Complexity
  (d.complexity || []).forEach(r => {
    addComplexityRow();
    const rows = [...document.querySelectorAll('#complexity-list .drow')];
    const lI = rows[rows.length - 1]?.id.replace('cmp-', '');
    if (lI != null) {
      sv(`cp-${lI}`, r.problem); sv(`cq-${lI}`, r.qualifier); sv(`cr-${lI}`, r.result);
      const cc = document.getElementById(`cc-${lI}`); if (cc) cc.value = r.class || 'hard';
    }
  });

  // Step 4 — Domains
  (d.domains || []).forEach(dom => {
    addDomain();
    const domCards = [...document.querySelectorAll('#domains-list .entry-card')];
    const dI = domCards[domCards.length - 1]?.id.replace('dom-', '');
    if (dI == null) return;
    sv(`dt-${dI}`, dom.title); sv(`dn-${dI}`, dom.notes); sv(`ds-${dI}`, dom.source);
    sv(`dss-${dI}`, dom.state_space); sv(`dg-${dI}`, dom.goal);
    const langSel = document.getElementById(`dl-${dI}`);
    if (langSel) {
      if ([...langSel.options].some(o => o.value === dom.language)) langSel.value = dom.language;
      else { langSel.value = 'Other'; sv(`dl-other-${dI}`, dom.language); document.getElementById(`dl-other-${dI}`).style.display = ''; }
    }
    (dom.types || []).forEach(t => {
      addType(+dI);
      const tyRows = [...document.querySelectorAll(`#type-list-${dI} .drow`)];
      const tI = tyRows[tyRows.length - 1]?.id.replace(`ty-${dI}-`, '');
      if (tI != null) { sv(`ty-name-${dI}-${tI}`, t.name); sv(`ty-par-${dI}-${tI}`, t.parent || 'object'); }
    });
    refreshTypeOpts(+dI);
    (dom.predicates || []).forEach(p => {
      addPredicate(+dI);
      const pCards = [...document.querySelectorAll(`#pred-list-${dI}>div`)];
      const pI = pCards[pCards.length - 1]?.id.replace(`pred-${dI}-`, '');
      if (pI != null) { sv(`pn-${dI}-${pI}`, p.name); sv(`pd-${dI}-${pI}`, p.desc); }
    });
    (dom.actions || []).forEach(a => {
      addAction(+dI);
      const aCards = [...document.querySelectorAll(`#act-list-${dI}>div`)];
      const aI = aCards[aCards.length - 1]?.id.replace(`act-${dI}-`, '');
      if (aI != null) {
        sv(`an-${dI}-${aI}`, a.name); sv(`ad-${dI}-${aI}`, a.desc);
        const schema = a.schema || '';
        const m = pat => { const x = schema.match(pat); return x ? x[1].trim() : ''; };
        const preEl = document.getElementById(`apc-${dI}-${aI}`);
        const addEl = document.getElementById(`aae-${dI}-${aI}`);
        const delEl = document.getElementById(`ade-${dI}-${aI}`);
        if (preEl) preEl.value = m(/^preconditions:\s*(.*)/m);
        if (addEl) addEl.value = m(/^add effects:\s*(.*)/m);
        if (delEl) delEl.value = m(/^del effects:\s*(.*)/m);
      }
    });
    (d.instances || []).filter(inst => inst.domain === dom.key).forEach(inst => {
      addInstance(+dI);
      const iDivs = [...document.querySelectorAll(`#inst-list-${dI}>div`)];
      const iI = iDivs[iDivs.length - 1]?.id.replace(`inst-${dI}-`, '');
      if (iI != null) {
        sv(`in-name-${dI}-${iI}`, inst.name); sv(`in-n-${dI}-${iI}`, inst.n);
        sv(`in-k-${dI}-${iI}`, inst.k); sv(`in-src-${dI}-${iI}`, inst.source);
        const stSel = document.getElementById(`in-st-${dI}-${iI}`); if (stSel) stSel.value = inst.status || 'unknown';
        const descEl = document.getElementById(`in-desc-${dI}-${iI}`); if (descEl) descEl.value = inst.description || '';
        if (inst._content && inst._file) setInstContent(+dI, +iI, inst._file, inst._content);
      }
    });
    if (dom._content && dom._file) setDomainContent(+dI, dom._file, dom._content);
    linkVariantToDomain(+dI);
  });

  // Apply variant hrefs now that domain options are populated
  refreshVariantLinkOpts();
  const varRows = [...document.querySelectorAll('#variants-list .drow')];
  (d.variants || []).forEach((v, idx) => {
    if (!v.href || !varRows[idx]) return;
    const rI = varRows[idx].id.replace('var-', '');
    const sel = document.getElementById(`vh-sel-${rI}`);
    const urlInp = document.getElementById(`vh-url-${rI}`);
    if (!sel) return;
    if (v.href.startsWith('http')) {
      sel.value = '__url__'; if (urlInp) { urlInp.value = v.href; urlInp.style.display = ''; }
    } else if ([...sel.options].some(o => o.value === v.href)) {
      sel.value = v.href;
    }
  });

  // Step 5 — References
  (d.references || []).forEach(ref => {
    addRef();
    const refCards = [...document.querySelectorAll('#refs-list .entry-card')];
    const rI = refCards[refCards.length - 1]?.id.replace('ref-', '');
    if (rI != null) {
      sv(`rk-${rI}`, ref.key); sv(`rt-${rI}`, ref.title); sv(`ra-${rI}`, ref.authors);
      sv(`rv-${rI}`, ref.venue); sv(`ru-${rI}`, ref.url); sv(`rn-${rI}`, ref.note);
    }
  });

  wizGo(0);
}

// ── Markdown generators ───────────────────────────────────────────────────────
function yamlList(arr) {
  return arr.length === 0 ? '[]' : '[' + arr.map(v => JSON.stringify(v)).join(', ') + ']';
}

function genGeneral() {
  const slug       = val('f-slug') || 'slug';
  const title      = val('f-title') || 'Untitled';
  const subtitle   = val('f-subtitle');
  const catSel     = document.getElementById('f-category').value;
  const category   = catSel === 'Other' ? (val('f-cat-other') || 'Other') : catSel;
  const originYear = val('f-origin-year');
  const origin     = val('f-origin');
  const proposers  = val('f-proposers').split(',').map(s => s.trim()).filter(Boolean);
  const tags       = checked('tags-grid');
  const langs      = checked('lang-grid');
  const ipc        = checked('ipc-grid');
  const desc       = val('f-desc');
  const history    = val('f-history');
  const variants   = getVariants();
  const complexity = getComplexity();
  const today      = new Date().toISOString().slice(0, 10);

  let o = `---\nslug: ${slug}\ntitle: ${title}\n`;
  if (subtitle)   o += `subtitle: ${JSON.stringify(subtitle)}\n`;
  o += `proposers: ${yamlList(proposers)}\n`;
  if (origin)     o += `origin: ${JSON.stringify(origin)}\n`;
  if (originYear) o += `origin_year: ${originYear}\n`;
  o += `last_updated: "${today}"\ncategory: ${category}\n`;
  o += `tags: ${yamlList(tags)}\nlanguages: ${yamlList(langs)}\nipc_editions: ${yamlList(ipc)}\n`;
  o += `---\n\n`;
  o += `## Description\n\n${desc || '<!-- TODO -->'}\n\n`;
  if (history) o += `## History\n\n${history}\n\n`;
  if (variants.length) {
    o += `## Variants\n\n`;
    variants.forEach(v => { o += v.href ? `- [${v.label}](${v.href})\n` : `- ${v.label}\n`; });
    o += '\n';
  }
  if (complexity.length) {
    o += `## Complexity\n\n| Problem | Qualifier | Result | Class |\n|---|---|---|---|\n`;
    complexity.forEach(r => { o += `| ${r.problem} | ${r.qualifier} | ${r.result} | ${r.cls} |\n`; });
    o += '\n';
  }
  return o.trimEnd() + '\n';
}

function genReferences() {
  const refs = getRefs();
  if (!refs.length) return null;

  let o = `## References\n\n`;
  refs.forEach(r => {
    o += `[${r.key}]: ${r.title}\n`;
    if (r.authors) o += `authors: ${r.authors}\n`;
    if (r.venue)   o += `venue: ${r.venue}\n`;
    if (r.url)     o += `url: ${r.url}\n`;
    if (r.note)    o += `note: ${r.note}\n`;
    o += '\n';
  });

  const bibtexEntries = refs.map(r => r.bibtex).filter(Boolean);
  if (bibtexEntries.length) {
    o += `## BibTeX\n\n\`\`\`bibtex\n${bibtexEntries.join('\n\n')}\n\`\`\`\n`;
  }
  return o.trimEnd() + '\n';
}

function genDomain(d) {
  let o = `---\ntitle: ${JSON.stringify(d.title || 'Untitled')}\nlanguage: ${d.lang}\n`;
  if (d.src)   o += `source: ${d.src}\n`;
  if (d.notes) o += `notes: ${JSON.stringify(d.notes)}\n`;
  o += `---\n\n`;
  if (d.ss) o += `## State Space\n\n${d.ss}\n\n`;
  if (d.types && d.types.length) {
    o += `## Types\n\n| name | parent |\n|---|---|\n`;
    d.types.forEach(t => { o += `| ${t.name} | ${t.parent || 'object'} |\n`; });
    o += '\n';
  }
  o += `## Predicates\n\n| name | desc |\n|---|---|\n`;
  if (d.predicates && d.predicates.length) {
    d.predicates.forEach(p => { o += `| ${p.name} | ${p.desc || ''} |\n`; });
  } else {
    o += `| pred(?x) | <!-- TODO --> |\n`;
  }
  o += '\n';
  if (d.actions && d.actions.length) {
    o += `## Actions\n\n`;
    d.actions.forEach(a => {
      o += `#### ${a.name}${a.desc ? ' — ' + a.desc : ''}\n`;
      const pre = a.preconditions || 'TODO';
      const add = a.add_effects   || 'TODO';
      const del = a.del_effects   || 'TODO';
      o += `\`\`\`\npreconditions: ${pre}\nadd effects:   ${add}\ndel effects:   ${del}\n\`\`\`\n\n`;
    });
  } else {
    o += `## Actions\n\n#### action(?x - type) — TODO: short description\n\`\`\`\npreconditions: TODO\nadd effects:   TODO\ndel effects:   TODO\n\`\`\`\n\n`;
  }
  o += d.goal ? `## Goal\n\n${d.goal}\n\n` : `## Goal\n\nTODO: describe the goal condition.\n\n`;
  o += `## Instances\n\n| name | n | opt. cost | status | source | file | description |\n|---|---|---|---|---|---|---|\n`;
  if (d.instances && d.instances.length) {
    d.instances.forEach(inst => {
      o += `| ${inst.name || 'instance-01'} | ${inst.n || '—'} | ${inst.k || '—'} | ${inst.status || 'unknown'} | ${inst.source || ''} | ${inst.file || ''} | ${inst.description || ''} |\n`;
    });
  } else {
    o += `| instance-01 | — | — | unknown | | instances/instance-01.pddl | |\n`;
  }
  return o.trimEnd() + '\n';
}

// ── Domain/instance file generators ──────────────────────────────────────────
function pddlReqs(lang) {
  const l = (lang || '').toLowerCase();
  if (l.includes('1.2'))   return ':strips';
  if (l.includes('2.1'))   return ':strips :typing';
  if (l.includes('2.2'))   return ':strips :typing :derived-predicates';
  if (l.includes('3.0'))   return ':strips :typing :preferences :constraints';
  if (l.includes('3.1'))   return ':strips :typing :preferences :constraints :object-fluents';
  if (l.includes('ppddl')) return ':strips :probabilistic-effects';
  if (l.includes('hddl'))  return ':strips :hierarchy :typing';
  return ':strips :typing';
}

function cmtChar(lang) {
  return (lang || '').toLowerCase().includes('rddl') ? '//' : ';';
}

function genDomainPddl(d) {
  const l   = (d.lang || '').toLowerCase();
  const c   = cmtChar(d.lang);
  const bar = `${c} ${'─'.repeat(58)}`;

  // ── Comment header pre-filled with user's data ─────────────────────────────
  let hdr = `${bar}\n${c} Domain:   ${d.key}\n${c} Language: ${d.lang}\n${c}\n`;
  hdr += `${c} TODO: complete the formal definition below.\n`;
  hdr += `${c}       The sections below summarise what you entered in the form.\n`;
  hdr += `${bar}\n`;

  if (d.types && d.types.length) {
    hdr += `${c}\n${c} TYPES\n`;
    d.types.forEach(t => {
      hdr += `${c}   ${t.name}` + (t.parent && t.parent !== 'object' ? `  →  ${t.parent}` : '') + '\n';
    });
  }

  if (d.predicates && d.predicates.length) {
    const pad = Math.max(...d.predicates.map(p => p.name.length), 0);
    hdr += `${c}\n${c} PREDICATES\n`;
    d.predicates.forEach(p => {
      const retNote = (p.returnType && p.returnType !== 'bool') ? ` [→ ${p.returnType}]` : '';
      hdr += `${c}   ${p.name.padEnd(pad)}${retNote}` + (p.desc ? `  —  ${p.desc}` : '') + '\n';
    });
  }

  if (d.actions && d.actions.length) {
    hdr += `${c}\n${c} ACTIONS\n`;
    d.actions.forEach(a => {
      hdr += `${c}   ${a.name}` + (a.desc ? `  —  ${a.desc}` : '') + '\n';
      if (a.preconditions) hdr += `${c}     Preconditions:  ${a.preconditions}\n`;
      if (a.add_effects)   hdr += `${c}     Add effects:    ${a.add_effects}\n`;
      if (a.del_effects)   hdr += `${c}     Delete effects: ${a.del_effects}\n`;
    });
  }

  hdr += `${bar}\n`;

  // Only generate formal syntax for PDDL variants (PDDL x.y, PPDDL)
  if (!l.includes('pddl')) {
    return hdr + `\n${c} TODO: write the formal domain definition in ${d.lang}\n`;
  }

  // ── PDDL family structural stub ────────────────────────────────────────────
  let s = `\n(define (domain ${d.key})\n  (:requirements ${pddlReqs(d.lang)})\n`;

  if (d.types && d.types.length) {
    s += `\n  (:types\n`;
    const byParent = {};
    d.types.forEach(t => {
      (byParent[t.parent || 'object'] = byParent[t.parent || 'object'] || []).push(t.name);
    });
    Object.entries(byParent).forEach(([p, ns]) => { s += `    ${ns.join(' ')} - ${p}\n`; });
    s += `  )\n`;
  }

  const boolPreds = (d.predicates || []).filter(p => !p.returnType || p.returnType === 'bool');
  const funcPreds = (d.predicates || []).filter(p => p.returnType && p.returnType !== 'bool');

  s += `\n  (:predicates\n`;
  if (boolPreds.length) {
    boolPreds.forEach(p => {
      const pname = p.name.split('(')[0];
      const ps = (p.params || []).length
        ? ' ' + p.params.map(pp => pp.type ? `?${pp.name} - ${pp.type}` : `?${pp.name}`).join(' ')
        : '';
      if (p.desc) s += `    ; ${p.desc}\n`;
      s += `    (${pname}${ps})\n`;
    });
  } else {
    s += `    ; TODO: add predicates\n`;
  }
  s += `  )\n`;

  if (funcPreds.length) {
    s += `\n  (:functions\n`;
    funcPreds.forEach(p => {
      const pname = p.name.split('(')[0];
      const ps = (p.params || []).length
        ? ' ' + p.params.map(pp => pp.type ? `?${pp.name} - ${pp.type}` : `?${pp.name}`).join(' ')
        : '';
      if (p.desc) s += `    ; ${p.desc}\n`;
      s += `    (${pname}${ps})` + (p.returnType !== 'number' ? ` ; → ${p.returnType}\n` : '\n');
    });
    s += `  )\n`;
  }

  if (d.actions && d.actions.length) {
    d.actions.forEach(a => {
      const aname = a.name.split('(')[0];
      const ps = (a.params || []).length
        ? a.params.map(p => p.type ? `?${p.name} - ${p.type}` : `?${p.name}`).join(' ')
        : '';
      s += `\n`;
      if (a.desc) s += `  ; ${a.desc}\n`;
      s += `  (:action ${aname}\n    :parameters (${ps})\n    :precondition (and\n`;
      if (a.preconditions && a.preconditions !== 'TODO') {
        s += `      ; ${a.preconditions}\n      ; TODO: translate to formal syntax\n`;
      } else {
        s += `      ; TODO\n`;
      }
      s += `    )\n    :effect (and\n`;
      if (a.add_effects && a.add_effects !== 'TODO')
        s += `      ; + ${a.add_effects}\n      ; TODO: translate to formal syntax\n`;
      if (a.del_effects && a.del_effects !== 'TODO')
        s += `      ; - ${a.del_effects}  →  (not ...)\n      ; TODO: translate to formal syntax\n`;
      if ((!a.add_effects || a.add_effects === 'TODO') && (!a.del_effects || a.del_effects === 'TODO'))
        s += `      ; TODO\n`;
      s += `    )\n  )\n`;
    });
  } else {
    s += `\n  ; TODO: add actions\n`;
  }

  return hdr + s + `)\n`;
}

function genInstancePddl(domain, inst) {
  const name  = (typeof inst === 'string') ? inst : (inst.name || 'instance');
  const slug  = slugify(name);
  const c     = cmtChar(domain.lang);
  const bar   = `${c} ${'─'.repeat(58)}`;

  let hdr = `${bar}\n${c} Instance: ${name}\n${c} Domain:   ${domain.key}\n`;
  if (typeof inst === 'object') {
    if (inst.n     && inst.n     !== '—') hdr += `${c} n:        ${inst.n}\n`;
    if (inst.k     && inst.k     !== '—') hdr += `${c} opt. cost: ${inst.k}\n`;
    if (inst.status && inst.status !== 'unknown') hdr += `${c} Status:   ${inst.status}\n`;
    if (inst.source)                              hdr += `${c} Source:   ${inst.source}\n`;
  }
  if (inst.description) hdr += `${c} ${inst.description}\n`;
  hdr += `${c}\n${c} TODO: fill in the objects, initial state, and goal.\n${bar}\n`;

  // Only generate formal syntax for PDDL variants
  const dl = (domain.lang || '').toLowerCase();
  if (!dl.includes('pddl')) {
    return hdr + `\n${c} TODO: write the formal instance definition in ${domain.lang}\n`;
  }

  return hdr + `\n(define (problem ${slug})\n  (:domain ${domain.key})\n\n  (:objects\n    ; TODO: list objects\n  )\n\n  (:init\n    ; TODO: list the facts that hold in the initial state\n  )\n\n  (:goal (and\n    ; TODO: goal condition\n  ))\n)\n`;
}

// ── Render output ─────────────────────────────────────────────────────────────
function renderOutput() {
  const slug = val('f-slug') || 'slug';
  document.getElementById('folder-hint').textContent = `problems/${slug}/`;

  const area = document.getElementById('output-area');
  area.innerHTML = '';

  function mkBlock(path, content) {
    const b = document.createElement('div');
    b.className = 'out-file';
    b.innerHTML = `
      <div class="out-hdr">
        <span class="out-path">${esc(path)}</span>
        <button class="dl-btn" onclick="dlText('${esc(path.split('/').pop())}', this.closest('.out-file').querySelector('pre').textContent)">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M5 1v5M2.5 4.5L5 7l2.5-2.5M1 8.5h8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
          Download
        </button>
      </div>
      <pre class="out-pre">${esc(content)}</pre>`;
    area.appendChild(b);
  }

  mkBlock('general.md', genGeneral());
  const refsMd = genReferences();
  if (refsMd) mkBlock('references.md', refsMd);
  getDomains().forEach(d => {
    mkBlock(`domains/${d.key}/domain.md`, genDomain(d));
    const df = domainFiles.get(d._idx);
    mkBlock(`domains/${d.key}/domain.pddl`, df ? df.content : genDomainPddl(d));
    d.instances.forEach(inst => {
      const iFile = instanceFiles.get(inst._fileKey);
      if (iFile) {
        mkBlock(`domains/${d.key}/instances/${iFile.name}`, iFile.content);
      } else if (inst.name) {
        mkBlock(`domains/${d.key}/instances/${slugify(inst.name)}.pddl`, genInstancePddl(d, inst));
      }
    });
  });

  if (!area.children.length)
    area.innerHTML = '<p style="color:var(--muted);font-size:13px">Fill in at least a title and one domain, then click Regenerate.</p>';
}

// ── ZIP download ──────────────────────────────────────────────────────────────
async function downloadZip() {
  const blocks = document.querySelectorAll('#output-area .out-file');
  if (!blocks.length) { renderOutput(); return; }

  const slug = val('f-slug') || 'problem';
  const zip = new JSZip();
  blocks.forEach(b => {
    zip.file(
      slug + '/' + b.querySelector('.out-path').textContent.trim(),
      b.querySelector('pre').textContent
    );
  });

  const blob = await zip.generateAsync({ type: 'blob' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `${val('f-slug') || 'problem'}.zip`;
  a.click();
  URL.revokeObjectURL(a.href);
}

// ── Utilities ─────────────────────────────────────────────────────────────────
function val(id) { const el = document.getElementById(id); return el ? el.value.trim() : ''; }
function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
function togglePre(preId, btn) {
  const pre = document.getElementById(preId);
  if (!pre) return;
  const open = pre.style.display === 'none';
  pre.style.display = open ? '' : 'none';
  btn.textContent = open ? '▴ hide' : '▾ view';
}
function dlText(filename, content) {
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([content], { type: 'text/plain' }));
  a.download = filename; a.click(); URL.revokeObjectURL(a.href);
}

document.addEventListener('DOMContentLoaded', () => {
  addDomain();
  const title = new URLSearchParams(window.location.search).get('title');
  if (title) {
    const el = document.getElementById('f-title');
    if (el) { el.value = title; el.dispatchEvent(new Event('input')); }
  }
});
</script>
</body>
