<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Submit a Problem | PlanLib</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;1,9..144,300&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="{{ base }}static/index.css" />
<style>
.wiz { max-width: 740px; margin: 0 auto; }

/* Step tabs */
.wiz-tabs {
  display: flex; margin-bottom: 28px;
  border: 1px solid var(--border); border-radius: 6px; overflow: hidden;
}
.wiz-tab {
  flex: 1; padding: 9px 4px; text-align: center;
  font-size: 10px; font-family: var(--mono); letter-spacing: .06em;
  color: var(--muted); border-right: 1px solid var(--border);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  cursor: pointer; transition: background .12s, color .12s;
}
.wiz-tab:last-child { border-right: none; }
.wiz-tab:hover:not(.active) { color: var(--text); }
.wiz-tab.active { background: var(--accent); color: #000; font-weight: 600; }
.wiz-tab.done { color: var(--accent); }

/* Panels */
.wiz-panel { display: none; }
.wiz-panel.active { display: block; }
.step-title { font-size: 20px; font-weight: 700; margin-bottom: 4px; }
.step-desc  { font-size: 13px; color: var(--muted); margin-bottom: 24px; line-height: 1.6; }

/* Inputs */
.fg { margin-bottom: 18px; }
.fl { display: block; font-size: 10px; font-family: var(--mono); letter-spacing: .08em; color: var(--accent); margin-bottom: 5px; }
.req { color: #cc5500; }
.fh { font-size: 11px; color: var(--muted); margin-top: 4px; line-height: 1.5; }
.fi, .ft, .fs {
  width: 100%; box-sizing: border-box;
  background: #0d1500; border: 1px solid #253000; border-radius: 4px;
  color: var(--text); font-family: var(--mono); font-size: 13px;
  padding: 8px 10px; outline: none; transition: border-color .15s;
}
.fi:focus, .ft:focus, .fs:focus { border-color: var(--accent); }
.ft { resize: vertical; min-height: 90px; }
.fs option { background: #0d1500; }
.frow  { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }

/* Validation */
@keyframes shake {
  0%,100% { transform: translateX(0); }
  20%,60% { transform: translateX(-5px); }
  40%,80% { transform: translateX(5px); }
}
.field-error { border-color: #cc4400 !important; animation: shake .3s ease; }
.err-msg { font-size: 11px; color: #cc4400; margin-top: 4px; display: none; }
.err-msg.show { display: block; }

/* Checkbox grid */
.cg { display: flex; flex-wrap: wrap; gap: 8px; }
.ci { display: flex; align-items: center; gap: 6px; cursor: pointer; }
.ci input[type=checkbox] { accent-color: var(--accent); width: 13px; height: 13px; }
.ci span { font-size: 12px; font-family: var(--mono); }

/* Dynamic rows */
.dyn { display: flex; flex-direction: column; gap: 8px; }
.drow { display: flex; gap: 8px; align-items: flex-start; }
.drow .fi { flex: 1; }
.rm-btn {
  background: none; border: 1px solid #333; border-radius: 4px;
  color: var(--muted); font-size: 16px; width: 28px; height: 34px; min-width: 28px;
  cursor: pointer; display: flex; align-items: center; justify-content: center;
  padding: 0; transition: border-color .15s, color .15s; line-height: 1;
}
.rm-btn:hover { border-color: #cc3300; color: #cc3300; }
.add-btn {
  display: inline-flex; align-items: center; gap: 6px; background: none;
  border: 1px solid var(--border); border-radius: 4px; color: var(--accent);
  font-size: 11px; font-family: var(--mono); letter-spacing: .06em;
  padding: 6px 12px; cursor: pointer; margin-top: 8px; transition: border-color .15s;
}
.add-btn:hover { border-color: var(--accent); }

/* Entry cards */
.entry-card { border: 1px solid var(--border); border-radius: 6px; padding: 16px; margin-bottom: 12px; }
.entry-card-hdr { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.entry-card-lbl { font-family: var(--mono); font-size: 11px; color: var(--accent); letter-spacing: .06em; }
.entry-rm {
  background: none; border: 1px solid #333; border-radius: 4px;
  color: var(--muted); font-size: 12px; font-family: var(--mono);
  padding: 3px 10px; cursor: pointer; transition: all .15s;
}
.entry-rm:hover { border-color: #cc3300; color: #cc3300; }
.bibtex-btn {
  background: none; border: 1px solid var(--border); border-radius: 4px;
  color: var(--muted); font-size: 11px; font-family: var(--mono);
  letter-spacing: .06em; padding: 5px 14px; cursor: pointer; transition: all .15s;
}
.bibtex-btn:hover { border-color: var(--accent); color: var(--accent); }

/* Section divider */
.sep { border: none; border-top: 1px solid var(--border); margin: 22px 0; }

/* Wizard nav */
.wiz-nav { display: flex; justify-content: space-between; align-items: center; margin-top: 28px; padding-top: 18px; border-top: 1px solid var(--border); }
.wiz-ctr { font-size: 11px; font-family: var(--mono); color: var(--muted); }
.wbtn { padding: 9px 22px; border-radius: 4px; font-family: var(--mono); font-size: 12px; letter-spacing: .06em; cursor: pointer; transition: all .15s; }
.wbtn-ghost { background: none; border: 1px solid var(--border); color: var(--muted); }
.wbtn-ghost:hover { border-color: var(--text); color: var(--text); }
.wbtn-primary { background: var(--accent); border: 1px solid var(--accent); color: #000; font-weight: 600; }
.wbtn-primary:hover { opacity: .85; }

/* Output */
.out-file { margin-bottom: 24px; }
.out-hdr  { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; gap: 12px; }
.out-path { font-family: var(--mono); font-size: 12px; color: var(--accent); word-break: break-all; }
.dl-btn {
  flex-shrink: 0; display: inline-flex; align-items: center; gap: 6px;
  background: none; border: 1px solid var(--accent); border-radius: 4px;
  color: var(--accent); font-size: 11px; font-family: var(--mono);
  letter-spacing: .06em; padding: 5px 12px; cursor: pointer; transition: all .15s;
}
.dl-btn:hover { background: var(--accent); color: #000; }
.out-pre {
  background: #060c00; border: 1px solid var(--border); border-radius: 4px;
  padding: 14px 16px; font-size: 11px; font-family: var(--mono); line-height: 1.55;
  overflow-x: auto; white-space: pre; color: var(--text); max-height: 280px; overflow-y: auto;
}
.zip-bar { display: flex; justify-content: flex-end; margin-bottom: 20px; }
.zip-btn {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--accent); border: 1px solid var(--accent); border-radius: 4px;
  color: #000; font-size: 12px; font-family: var(--mono); font-weight: 600;
  letter-spacing: .06em; padding: 9px 20px; cursor: pointer; transition: opacity .15s;
}
.zip-btn:hover { opacity: .85; }
.next-steps { background: #0a1800; border: 1px solid var(--border); border-radius: 6px; padding: 20px; margin-top: 24px; }
.next-steps-lbl { font-size: 11px; font-family: var(--mono); color: var(--accent); letter-spacing: .06em; margin-bottom: 12px; }
.next-steps p { font-size: 13px; color: var(--text); line-height: 1.8; margin: 0; }
.ic { font-family: var(--mono); background: #1a2a00; padding: 1px 5px; border-radius: 3px; }
.tbl-col-hdr { font-size: 10px; font-family: var(--mono); color: var(--muted); letter-spacing: .06em; padding: 0 2px; }
.dom-section-lbl { font-size: 10px; font-family: var(--mono); color: var(--accent); letter-spacing: .06em; margin: 14px 0 6px; }
.drop-zone {
  border: 1px dashed var(--border); border-radius: 4px; padding: 14px 10px;
  text-align: center; font-size: 12px; font-family: var(--mono); color: var(--muted);
  cursor: pointer; transition: border-color .15s, color .15s; line-height: 1.5; box-sizing: border-box;
}
.drop-zone:hover, .drop-zone.dz-over { border-color: var(--accent); color: var(--accent); }
.drop-zone.dz-loaded { border-style: solid; border-color: var(--accent); color: var(--text); }
.drop-zone-sm { padding: 6px 10px; }
.dz-rm {
  display: none; align-items: center; gap: 4px; margin-top: 5px;
  background: none; border: 1px solid #333; border-radius: 4px;
  color: var(--muted); font-size: 11px; font-family: var(--mono);
  letter-spacing: .04em; padding: 3px 10px; cursor: pointer; transition: all .15s;
}
.dz-rm:hover { border-color: #cc3300; color: #cc3300; }
</style>
</head>
<body>

<nav class="topbar">
  <div class="topbar-left">
    <a class="topbar-logo" href="{{ base }}">PlanLib</a>
    <span class="topbar-sep">›</span>
    <span class="topbar-crumb">Submit a Problem</span>
  </div>
  <div class="topbar-nav">
    <a href="{{ base }}problems/">Problems</a>
    <a href="{{ base }}languages/">Languages</a>
    <a href="{{ base }}ipc/">IPC</a>
    <a href="{{ base }}tags/">Tags</a>
    <a href="{{ base }}#about">About</a>
    <a href="{{ base }}contribute/">Contribute</a>
    <a href="https://github.com/planlib/planlib" target="_blank" rel="noopener">GitHub ↗</a>
  </div>
</nav>

<section class="hero" style="padding-top:48px;padding-bottom:40px">
  <div class="hero-label">PlanLib</div>
  <h1 class="hero-title" style="font-size:clamp(28px,4vw,44px);margin-bottom:0">Submit a Problem</h1>
  <p class="hero-body" style="margin-top:14px;margin-bottom:0">Fill in the form to generate the Markdown source files for a new planning problem. Download them, add to your fork, and open a pull request.</p>
</section>

<section class="section" style="padding-top:36px;padding-bottom:72px">
<div class="wiz">

  {% if problems_data %}
  <!-- Load existing problem -->
  <div style="background:#0a1200;border:1px solid var(--border);border-radius:6px;padding:12px 16px;margin-bottom:20px;display:flex;align-items:center;gap:10px;flex-wrap:wrap">
    <span style="font-size:10px;font-family:var(--mono);color:var(--accent);letter-spacing:.08em;white-space:nowrap">LOAD EXISTING</span>
    <select id="load-prob-sel" class="fs" style="flex:1;min-width:180px;max-width:380px;padding:6px 8px">
      <option value="">+ New problem</option>
      {% for p in problems_data %}<option value="{{ loop.index0 }}">{{ p.title }}</option>
      {% endfor %}
    </select>
    <button type="button" class="add-btn" style="margin:0" onclick="loadSelectedProblem()">Load →</button>
    <span id="load-ok" style="font-size:11px;font-family:var(--mono);color:var(--accent);display:none">✓ Loaded — edit and re-download</span>
  </div>
  {% endif %}

  <!-- Step tabs -->
  <div class="wiz-tabs">
    <div class="wiz-tab active" onclick="tryGoTo(0)">Identity</div>
    <div class="wiz-tab" onclick="tryGoTo(1)">Tags</div>
    <div class="wiz-tab" onclick="tryGoTo(2)">Description</div>
    <div class="wiz-tab" onclick="tryGoTo(3)">Variants</div>
    <div class="wiz-tab" onclick="tryGoTo(4)">Domains</div>
    <div class="wiz-tab" onclick="tryGoTo(5)">References</div>
    <div class="wiz-tab" onclick="tryGoTo(6)">Download</div>
  </div>

  <!-- ══════════════════════════════════════════ STEP 0 — Identity -->
  <div class="wiz-panel active" id="panel-0">
    <div class="step-title">Problem Identity</div>
    <div class="step-desc">Core metadata. A stable identifier is assigned by a maintainer when the pull request is merged — you don't need to pick one.</div>

    <div class="fg">
      <label class="fl">Title <span class="req">*</span></label>
      <input class="fi" id="f-title" type="text" placeholder="Mystery" />
      <div class="err-msg" id="err-f-title">Title is required.</div>
    </div>

    <div class="fg">
      <label class="fl">Slug <span class="req">*</span></label>
      <input class="fi" id="f-slug" type="text" placeholder="mystery" />
      <div class="fh">URL-safe folder name — auto-filled from the title, but you can edit it.</div>
      <div class="err-msg" id="err-f-slug">Slug is required.</div>
    </div>

    <div class="fg">
      <label class="fl">Subtitle <span class="req">*</span></label>
      <textarea class="ft" id="f-subtitle" rows="3" placeholder="One- or two-sentence description shown on the problem list…"></textarea>
      <div class="err-msg" id="err-f-subtitle">Subtitle is required.</div>
    </div>

    <div class="frow">
      <div class="fg">
        <label class="fl">Category</label>
        <select class="fs" id="f-category" onchange="toggleOther(this,'f-cat-other')">
          <option>Classical</option><option>Temporal</option><option>Numeric</option>
          <option>Probabilistic</option><option>HTN</option><option>Multi-Agent</option>
          <option>Partially Observable</option><option value="Other">Other</option>
        </select>
        <input class="fi" id="f-cat-other" type="text" placeholder="Category name…" style="display:none;margin-top:6px" />
      </div>
      <div class="fg">
        <label class="fl">Origin Year</label>
        <input class="fi" id="f-origin-year" type="number" placeholder="1995" min="1950" max="2030" />
      </div>
    </div>

    <div class="fg">
      <label class="fl">Origin Reference</label>
      <input class="fi" id="f-origin" type="text" placeholder="Kautz &amp; Selman, 1992" />
      <div class="fh">Author and year of the publication that introduced this domain.</div>
    </div>

    <div class="fg">
      <label class="fl">Proposers</label>
      <input class="fi" id="f-proposers" type="text" placeholder="Henry Kautz, Bart Selman" />
      <div class="fh">Comma-separated list of the original authors.</div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════ STEP 1 — Tags -->
  <div class="wiz-panel" id="panel-1">
    <div class="step-title">Tags &amp; Classification</div>
    <div class="step-desc">Check all that apply. Custom entries can be added at the bottom of each section.</div>

    <div class="fg">
      <label class="fl">Tags</label>
      <div class="cg" id="tags-grid">
        <label class="ci"><input type="checkbox" value="Classical" /><span>Classical</span></label>
        <label class="ci"><input type="checkbox" value="Fully Observable" /><span>Fully Observable</span></label>
        <label class="ci"><input type="checkbox" value="Deterministic" /><span>Deterministic</span></label>
        <label class="ci"><input type="checkbox" value="Single Agent" /><span>Single Agent</span></label>
        <label class="ci"><input type="checkbox" value="Multi-Agent" /><span>Multi-Agent</span></label>
        <label class="ci"><input type="checkbox" value="STRIPS" /><span>STRIPS</span></label>
        <label class="ci"><input type="checkbox" value="Typed" /><span>Typed</span></label>
        <label class="ci"><input type="checkbox" value="Numeric" /><span>Numeric</span></label>
        <label class="ci"><input type="checkbox" value="Temporal" /><span>Temporal</span></label>
        <label class="ci"><input type="checkbox" value="Stochastic" /><span>Stochastic</span></label>
        <label class="ci"><input type="checkbox" value="Partially Observable" /><span>Partially Observable</span></label>
        <label class="ci"><input type="checkbox" value="Hierarchical" /><span>Hierarchical</span></label>
        <label class="ci"><input type="checkbox" value="Transportation" /><span>Transportation</span></label>
        <label class="ci"><input type="checkbox" value="Scheduling" /><span>Scheduling</span></label>
        <label class="ci"><input type="checkbox" value="Stacking" /><span>Stacking</span></label>
        <label class="ci"><input type="checkbox" value="Multi-Object" /><span>Multi-Object</span></label>
      </div>
      <div style="display:flex;gap:8px;margin-top:10px;align-items:center">
        <input class="fi" id="tag-custom" type="text" placeholder="Custom tag…" style="max-width:200px" />
        <button type="button" class="add-btn" onclick="addCustom('tags-grid','tag-custom')">+ Add</button>
      </div>
    </div>

    <hr class="sep" />

    <div class="fg">
      <label class="fl">Languages</label>
      <div class="cg" id="lang-grid">
        <label class="ci"><input type="checkbox" value="PDDL 1.2" /><span>PDDL 1.2</span></label>
        <label class="ci"><input type="checkbox" value="PDDL 2.1" /><span>PDDL 2.1</span></label>
        <label class="ci"><input type="checkbox" value="PDDL 2.2" /><span>PDDL 2.2</span></label>
        <label class="ci"><input type="checkbox" value="PDDL 3.0" /><span>PDDL 3.0</span></label>
        <label class="ci"><input type="checkbox" value="PDDL 3.1" /><span>PDDL 3.1</span></label>
        <label class="ci"><input type="checkbox" value="PPDDL" /><span>PPDDL</span></label>
        <label class="ci"><input type="checkbox" value="RDDL" /><span>RDDL</span></label>
        <label class="ci"><input type="checkbox" value="HDDL" /><span>HDDL</span></label>
        <label class="ci"><input type="checkbox" value="MAPL" /><span>MAPL</span></label>
      </div>
      <div style="display:flex;gap:8px;margin-top:10px;align-items:center">
        <input class="fi" id="lang-custom" type="text" placeholder="Custom language…" style="max-width:200px" />
        <button type="button" class="add-btn" onclick="addCustom('lang-grid','lang-custom')">+ Add</button>
      </div>
    </div>

    <hr class="sep" />

    <div class="fg">
      <label class="fl">IPC Editions</label>
      <div class="cg" id="ipc-grid">
        <label class="ci"><input type="checkbox" value="IPC 1998" /><span>IPC 1998</span></label>
        <label class="ci"><input type="checkbox" value="IPC 2000" /><span>IPC 2000</span></label>
        <label class="ci"><input type="checkbox" value="IPC 2002" /><span>IPC 2002</span></label>
        <label class="ci"><input type="checkbox" value="IPC 2004" /><span>IPC 2004</span></label>
        <label class="ci"><input type="checkbox" value="IPC 2006" /><span>IPC 2006</span></label>
        <label class="ci"><input type="checkbox" value="IPC 2008" /><span>IPC 2008</span></label>
        <label class="ci"><input type="checkbox" value="IPC 2011" /><span>IPC 2011</span></label>
        <label class="ci"><input type="checkbox" value="IPC 2014" /><span>IPC 2014</span></label>
        <label class="ci"><input type="checkbox" value="IPC 2018" /><span>IPC 2018</span></label>
        <label class="ci"><input type="checkbox" value="IPC 2023" /><span>IPC 2023</span></label>
      </div>
    </div>
  </div>

  <!-- ══════════════════════════════════════════ STEP 2 — Description -->
  <div class="wiz-panel" id="panel-2">
    <div class="step-title">Description &amp; History</div>
    <div class="step-desc">Write the main description and historical context. Plain text or Markdown. Cite references with <span class="ic">[Key]</span> notation.</div>

    <div class="fg">
      <label class="fl">Description <span class="req">*</span></label>
      <textarea class="ft" id="f-desc" rows="9" placeholder="Describe the planning problem: the physical setup, the goal, what makes it interesting or challenging…"></textarea>
      <div class="err-msg" id="err-f-desc">Description is required.</div>
    </div>

    <div class="fg">
      <label class="fl">History</label>
      <textarea class="ft" id="f-history" rows="5" placeholder="When and where was this domain introduced? Which planners used it? Major milestones…"></textarea>
    </div>
  </div>

  <!-- ══════════════════════════════════════════ STEP 3 — Variants & Complexity -->
  <div class="wiz-panel" id="panel-3">
    <div class="step-title">Variants &amp; Complexity</div>
    <div class="step-desc">List known variants and, optionally, computational complexity results.</div>

    <div class="fg">
      <label class="fl">Variants</label>
      <div class="dyn" id="variants-list"></div>
      <button type="button" class="add-btn" onclick="addVariant()">+ Add variant</button>
    </div>

    <hr class="sep" />

    <div class="fg">
      <label class="fl">Complexity Results</label>
      <div class="fh" style="margin-bottom:10px">Known computational complexity. Class: <span class="ic">hard</span> / <span class="ic">easy</span> / <span class="ic">open</span></div>
      <div id="complexity-list"></div>
      <button type="button" class="add-btn" onclick="addComplexityRow()">+ Add result</button>
    </div>

  </div>

  <!-- ══════════════════════════════════════════ STEP 4 — Domains -->
  <div class="wiz-panel" id="panel-4">
    <div class="step-title">Domains</div>
    <div class="step-desc">Add at least one domain variant. Each generates a <span class="ic">domain.md</span> and a <span class="ic">domain.pddl</span> (uploaded file or a typed placeholder). Instances each get their own <span class="ic">.pddl</span> file too.</div>

    <div id="domains-list"></div>
    <button type="button" class="add-btn" onclick="addDomain()">+ Add domain</button>
  </div>

  <!-- ══════════════════════════════════════════ STEP 5 — References -->
  <div class="wiz-panel" id="panel-5">
    <div class="step-title">References</div>
    <div class="step-desc">Add the papers cited in your description. Fill in the fields, then click <strong style="color:var(--text)">→ Generate BibTeX</strong> to auto-fill the entry for that reference.</div>

    <div id="refs-list"></div>
    <button type="button" class="add-btn" onclick="addRef()">+ Add reference</button>
  </div>

  <!-- ══════════════════════════════════════════ STEP 6 — Download -->
  <div class="wiz-panel" id="panel-6">
    <div class="step-title">Generated Files</div>
    <div class="step-desc">Extract the ZIP into a new folder inside <span class="ic">problems/</span> in your fork, then open a pull request. A maintainer will assign a stable identifier on merge.</div>

    <div class="zip-bar">
      <button class="zip-btn" onclick="downloadZip()">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M6 1v7M3 6l3 3 3-3M1 10h10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
        Download all as ZIP
      </button>
    </div>

    <div id="output-area"></div>

    <div class="next-steps">
      <div class="next-steps-lbl">NEXT STEPS</div>
      <p>
        1. Fork the <a href="https://github.com/planlib/planlib" target="_blank" rel="noopener" style="color:var(--accent)">planlib repository</a> on GitHub.<br>
        2. Extract the ZIP directly into <span class="ic">problems/</span> — it unpacks into a <span id="folder-hint" class="ic">slug/</span> folder automatically.<br>
        3. You'll get <span class="ic">general.md</span>, <span class="ic">references.md</span>, and a <span class="ic">domains/</span> subfolder with the <span class="ic">domain.md</span> and the domain file. Any uploaded instance files land in <span class="ic">domains/&lt;key&gt;/instances/</span>; generated placeholder files need to be filled in.<br>
        4. Run <span class="ic">python planlib_build.py build --all</span> locally to verify the build passes.<br>
        5. Open a pull request — CI will re-run the build automatically. A maintainer will assign a stable identifier on merge.
      </p>
    </div>
  </div>

  <!-- Wizard navigation -->
  <div class="wiz-nav">
    <button class="wbtn wbtn-ghost" id="btn-prev" onclick="wizPrev()" style="visibility:hidden">← Back</button>
    <span class="wiz-ctr" id="wiz-ctr">Step 1 of 7</span>
    <button class="wbtn wbtn-primary" id="btn-next" onclick="wizNext()">Next →</button>
  </div>

<datalist id="variant-opts"></datalist>
</div>
</section>

<footer class="footer">
  <span>PlanLib — AI Planning Problem Library</span>
  <span><a href="https://github.com/planlib/planlib" target="_blank" rel="noopener">GitHub</a> · <a href="#">Cite</a> · <a href="#">Contact</a></span>
</footer>

<script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js"></script>
<script>
// ── Constants ─────────────────────────────────────────────────────────────────
const NSTEPS = 7;
let cur = 0;
const PLANLIB_PROBLEMS = {{ (problems_data | tojson) if problems_data is defined and problems_data else '[]' }};

const REQUIRED = {
  0: [['f-title','Title'], ['f-slug','Slug'], ['f-subtitle','Subtitle']],
  2: [['f-desc','Description']],
};

// ── Validation ────────────────────────────────────────────────────────────────
function validateStep(n) {
  const fields = REQUIRED[n] || [];
  let ok = true;
  fields.forEach(([id]) => {
    const el = document.getElementById(id);
    if (!el || !el.value.trim()) { markError(el, id); ok = false; }
  });
  return ok;
}

function markError(el, id) {
  if (!el) return;
  el.classList.add('field-error');
  const msg = id ? document.getElementById('err-' + id) : null;
  if (msg) msg.classList.add('show');
  el.addEventListener('input', () => {
    el.classList.remove('field-error');
    if (msg) msg.classList.remove('show');
  }, { once: true });
  el.focus();
}

// ── Wizard navigation ─────────────────────────────────────────────────────────
function wizGo(n) {
  document.querySelectorAll('.wiz-panel').forEach((p, i) => p.classList.toggle('active', i === n));
  document.querySelectorAll('.wiz-tab').forEach((t, i) => {
    t.classList.toggle('active', i === n);
    t.classList.toggle('done', i < n);
  });
  document.getElementById('btn-prev').style.visibility = n === 0 ? 'hidden' : 'visible';
  const nb = document.getElementById('btn-next');
  if (n === NSTEPS - 1) { nb.textContent = '↺ Regenerate'; nb.onclick = renderOutput; }
  else                  { nb.textContent = 'Next →';       nb.onclick = wizNext; }
  document.getElementById('wiz-ctr').textContent = `Step ${n + 1} of ${NSTEPS}`;
  cur = n;
  if (n === NSTEPS - 1) renderOutput();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function wizNext() {
  if (!validateStep(cur)) return;
  if (cur < NSTEPS - 1) wizGo(cur + 1);
}
function wizPrev() { if (cur > 0) wizGo(cur - 1); }

function tryGoTo(n) {
  if (n === cur) return;
  if (n > cur && !validateStep(cur)) return;
  wizGo(n);
}

// ── Auto-slug ─────────────────────────────────────────────────────────────────
document.getElementById('f-title').addEventListener('input', function () {
  document.getElementById('f-slug').value =
    this.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
});

// ── "Other" reveal ────────────────────────────────────────────────────────────
function toggleOther(sel, targetId) {
  const inp = document.getElementById(targetId);
  if (!inp) return;
  const show = sel.value === 'Other';
  inp.style.display = show ? '' : 'none';
  if (show) inp.focus();
}

// ── Checkbox grids ────────────────────────────────────────────────────────────
function addCustom(gridId, inputId) {
  const inp = document.getElementById(inputId);
  const v = inp.value.trim(); if (!v) return;
  const lbl = document.createElement('label');
  lbl.className = 'ci';
  lbl.innerHTML = `<input type="checkbox" value="${esc(v)}" checked /><span>${esc(v)}</span>`;
  document.getElementById(gridId).appendChild(lbl);
  inp.value = '';
}
function checked(gridId) {
  return [...document.querySelectorAll(`#${gridId} input[type=checkbox]:checked`)].map(c => c.value);
}

// ── Variants ──────────────────────────────────────────────────────────────────
let vi = 0;
function addVariant() {
  const i = vi++;
  const d = document.createElement('div');
  d.className = 'drow'; d.id = `var-${i}`;
  d.innerHTML = `
    <input class="fi" id="vl-${i}" type="text" placeholder="Variant name" style="flex:2" oninput="refreshVariantOpts()" />
    <div style="flex:3;display:flex;gap:6px">
      <select class="fs" id="vh-sel-${i}" style="flex:1" onchange="onVariantLinkChange(${i})">
        <option value="">(no link)</option>
        <option value="__url__">External URL…</option>
      </select>
      <input class="fi" id="vh-url-${i}" type="text" placeholder="https://…" style="flex:1.5;display:none" />
    </div>
    <button type="button" class="rm-btn" onclick="document.getElementById('var-${i}').remove()">×</button>`;
  document.getElementById('variants-list').appendChild(d);
  refreshVariantLinkOpts();
}
function onVariantLinkChange(i) {
  const sel = document.getElementById(`vh-sel-${i}`);
  const url = document.getElementById(`vh-url-${i}`);
  if (!url) return;
  const showUrl = sel && sel.value === '__url__';
  url.style.display = showUrl ? '' : 'none';
  if (!showUrl) url.value = '';
}
function getVariants() {
  return [...document.querySelectorAll('#variants-list .drow')].map(r => {
    const i = r.id.replace('var-', '');
    const sel = document.getElementById(`vh-sel-${i}`);
    const selVal = sel ? sel.value : '';
    const href = selVal === '__url__' ? val(`vh-url-${i}`) : selVal;
    return { label: val(`vl-${i}`), href };
  }).filter(v => v.label);
}
function refreshVariantOpts() {
  const dl = document.getElementById('variant-opts');
  if (!dl) return;
  dl.innerHTML = getVariants().map(v => `<option value="${esc(v.label)}">`).join('');
}
function refreshVariantLinkOpts() {
  const domains = [...document.querySelectorAll('#domains-list .entry-card')].map(r => {
    const i = r.id.replace('dom-', '');
    const title = val(`dt-${i}`);
    return { title, slug: slugify(title) };
  }).filter(d => d.title);
  document.querySelectorAll('#variants-list .drow').forEach(r => {
    const i = r.id.replace('var-', '');
    const sel = document.getElementById(`vh-sel-${i}`);
    if (!sel) return;
    const current = sel.value;
    [...sel.options].filter(o => o.value !== '' && o.value !== '__url__').forEach(o => o.remove());
    const urlOpt = sel.querySelector('option[value="__url__"]');
    domains.forEach(d => {
      const opt = new Option(d.title, `#domain-${d.slug}`);
      sel.insertBefore(opt, urlOpt);
    });
    if ([...sel.options].some(o => o.value === current)) sel.value = current;
  });
}
function linkVariantToDomain(domIdx) {
  const title = val(`dt-${domIdx}`);
  refreshVariantLinkOpts();
  if (!title) return;
  const targetHref = `#domain-${slugify(title)}`;
  document.querySelectorAll('#variants-list .drow').forEach(r => {
    const i = r.id.replace('var-', '');
    if (val(`vl-${i}`).toLowerCase() === title.toLowerCase()) {
      const sel = document.getElementById(`vh-sel-${i}`);
      if (sel && sel.value === '') sel.value = targetHref;
    }
  });
}

// ── Complexity ────────────────────────────────────────────────────────────────
let cxi = 0;
function addComplexityRow() {
  const i = cxi++;
  const d = document.createElement('div');
  d.className = 'drow'; d.id = `cmp-${i}`;
  d.innerHTML = `
    <input class="fi" id="cp-${i}" type="text" placeholder="Problem" style="flex:3" />
    <input class="fi" id="cq-${i}" type="text" placeholder="Qualifier" style="flex:2" />
    <input class="fi" id="cr-${i}" type="text" placeholder="Result" style="flex:2" />
    <select class="fs" id="cc-${i}" style="flex:1;padding:8px 6px">
      <option value="hard">hard</option><option value="easy">easy</option><option value="open">open</option>
    </select>
    <button type="button" class="rm-btn" onclick="document.getElementById('cmp-${i}').remove()">×</button>`;
  document.getElementById('complexity-list').appendChild(d);
}
function getComplexity() {
  return [...document.querySelectorAll('#complexity-list .drow')].map(r => {
    const i = r.id.replace('cmp-', '');
    return { problem: val(`cp-${i}`), qualifier: val(`cq-${i}`), result: val(`cr-${i}`), cls: val(`cc-${i}`) };
  }).filter(r => r.problem);
}


// ── Domains ───────────────────────────────────────────────────────────────────
function slugify(s) {
  return (s || '').toLowerCase().trim().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') || 'domain';
}

let di = 0;
function addDomain() {
  const i = di++;
  const d = document.createElement('div');
  d.className = 'entry-card'; d.id = `dom-${i}`;
  d.innerHTML = `
    <div class="entry-card-hdr">
      <span class="entry-card-lbl">Domain</span>
      <button type="button" class="entry-rm" onclick="document.getElementById('dom-${i}').remove()">Remove</button>
    </div>
    <div class="fg">
      <label class="fl">Domain Title <span class="req">*</span></label>
      <input class="fi" id="dt-${i}" type="text" placeholder="PDDL Domain (base)" list="variant-opts" oninput="linkVariantToDomain(${i})" />
      <div class="fh">The folder slug is derived from this — e.g. "PDDL Domain (base)" → <span class="ic">domains/pddl-domain-base/</span></div>
    </div>
    <div class="frow" style="margin-top:10px">
      <div class="fg" style="margin:0">
        <label class="fl">Language</label>
        <select class="fs" id="dl-${i}" onchange="toggleOther(this,'dl-other-${i}')">
          <option>PDDL 1.2</option><option selected>PDDL 2.1</option><option>PDDL 2.2</option>
          <option>PDDL 3.0</option><option>PDDL 3.1</option><option>PPDDL</option>
          <option>RDDL</option><option>HDDL</option><option value="Other">Other</option>
        </select>
        <input class="fi" id="dl-other-${i}" type="text" placeholder="Language name…" style="display:none;margin-top:6px" />
      </div>
      <div class="fg" style="margin:0">
        <label class="fl">Source Reference Key</label>
        <input class="fi" id="ds-${i}" type="text" placeholder="Author99" />
      </div>
    </div>
    <div class="fg" style="margin-top:10px">
      <label class="fl">Notes</label>
      <textarea class="ft" id="dn-${i}" rows="2" placeholder="Brief notes about this variant…"></textarea>
    </div>
    <div class="fg" style="margin-top:10px">
      <label class="fl">Domain File</label>
      <div class="drop-zone" id="dz-dom-${i}"
           ondragover="event.preventDefault();this.classList.add('dz-over')"
           ondragleave="this.classList.remove('dz-over')"
           ondrop="handleDomainDrop(event,${i})"
           onclick="document.getElementById('df-dom-${i}').click()">
        <span id="dz-dom-lbl-${i}">Drop domain file here or <u>browse</u></span>
      </div>
      <input type="file" id="df-dom-${i}" accept=".pddl,.lisp" style="display:none" onchange="handleDomainFile(event,${i})" />
      <button type="button" class="dz-rm" id="dz-dom-rm-${i}" onclick="removeDomainFile(${i})">× Remove file</button>
      <pre id="dz-dom-pre-${i}" style="display:none;margin-top:6px;max-height:220px;overflow:auto;font-size:11px;line-height:1.5;background:#060c00;border:1px solid var(--border);border-radius:4px;padding:10px;color:var(--text);white-space:pre"></pre>
    </div>
    <div style="font-size:10px;font-family:var(--mono);color:var(--muted);letter-spacing:.06em;margin:18px 0 8px">
      FORMAL SECTIONS — optional, can also be edited in the downloaded file</div>
    <div class="fg">
      <label class="fl">State Space</label>
      <textarea class="ft" id="dss-${i}" rows="2" placeholder="Describe the state space…"></textarea>
    </div>
    <datalist id="type-opts-${i}"><option value="object"></datalist>
    <div class="dom-section-lbl">TYPES</div>
    <div style="display:grid;grid-template-columns:1fr 1fr 28px;gap:6px;margin-bottom:4px">
      <span class="tbl-col-hdr">name</span><span class="tbl-col-hdr">parent type</span><span></span>
    </div>
    <div id="type-list-${i}"></div>
    <button type="button" class="add-btn" style="margin-top:4px;margin-bottom:14px" onclick="addType(${i})">+ Add type</button>
    <div class="dom-section-lbl">PREDICATES</div>
    <div id="pred-list-${i}"></div>
    <button type="button" class="add-btn" style="margin-top:4px;margin-bottom:14px" onclick="addPredicate(${i})">+ Add predicate</button>
    <div class="dom-section-lbl">ACTIONS</div>
    <div id="act-list-${i}"></div>
    <button type="button" class="add-btn" style="margin-top:4px;margin-bottom:10px" onclick="addAction(${i})">+ Add action</button>
    <div class="fg">
      <label class="fl">Goal</label>
      <textarea class="ft" id="dg-${i}" rows="2" placeholder="Describe the goal condition…"></textarea>
    </div>
    <div style="font-size:10px;font-family:var(--mono);color:var(--muted);letter-spacing:.06em;margin:14px 0 8px">INSTANCES</div>
    <div id="inst-list-${i}"></div>
    <button type="button" class="add-btn" style="margin-top:4px" onclick="addInstance(${i})">+ Add instance</button>`;
  document.getElementById('domains-list').appendChild(d);
}

// ── PDDL file stores ─────────────────────────────────────────────────────────
const domainFiles   = new Map(); // domIdx (number) -> {name, content}
const instanceFiles = new Map(); // `${domIdx}-${instIdx}` -> {name, content}

function handleDomainDrop(event, domIdx) {
  event.preventDefault();
  event.currentTarget.classList.remove('dz-over');
  const file = event.dataTransfer.files[0];
  if (file) loadDomainFile(domIdx, file);
}
function handleDomainFile(event, domIdx) {
  const file = event.target.files[0];
  if (file) loadDomainFile(domIdx, file);
}
function _applyDomainLoaded(domIdx, name, content) {
  const lbl = document.getElementById(`dz-dom-lbl-${domIdx}`);
  const dz  = document.getElementById(`dz-dom-${domIdx}`);
  const rm  = document.getElementById(`dz-dom-rm-${domIdx}`);
  const pre = document.getElementById(`dz-dom-pre-${domIdx}`);
  if (lbl) lbl.innerHTML = `✓ ${esc(name)} <span style="font-size:10px;color:var(--accent);cursor:pointer;text-decoration:underline;text-underline-offset:2px;margin-left:6px" onclick="event.stopPropagation();togglePre('dz-dom-pre-${domIdx}',this)">▾ view</span>`;
  if (dz)  dz.classList.add('dz-loaded');
  if (rm)  rm.style.display = 'inline-flex';
  if (pre) pre.textContent = content;
}
function loadDomainFile(domIdx, file) {
  const reader = new FileReader();
  reader.onload = e => {
    domainFiles.set(domIdx, { name: file.name, content: e.target.result });
    _applyDomainLoaded(domIdx, file.name, e.target.result);
  };
  reader.readAsText(file);
}
function setDomainContent(domIdx, filename, content) {
  if (!filename || !content) return;
  domainFiles.set(domIdx, { name: filename, content });
  _applyDomainLoaded(domIdx, filename, content);
}

function removeDomainFile(domIdx) {
  domainFiles.delete(domIdx);
  const lbl = document.getElementById(`dz-dom-lbl-${domIdx}`);
  const dz  = document.getElementById(`dz-dom-${domIdx}`);
  const rm  = document.getElementById(`dz-dom-rm-${domIdx}`);
  const inp = document.getElementById(`df-dom-${domIdx}`);
  const pre = document.getElementById(`dz-dom-pre-${domIdx}`);
  if (lbl) lbl.innerHTML = 'Drop domain file here or <u>browse</u>';
  if (dz)  dz.classList.remove('dz-loaded');
  if (rm)  rm.style.display = 'none';
  if (inp) inp.value = '';
  if (pre) { pre.textContent = ''; pre.style.display = 'none'; }
}

function handleInstDrop(event, domIdx, instIdx) {
  event.preventDefault();
  event.currentTarget.classList.remove('dz-over');
  const file = event.dataTransfer.files[0];
  if (file) loadInstFile(domIdx, instIdx, file);
}
function handleInstFile(event, domIdx, instIdx) {
  const file = event.target.files[0];
  if (file) loadInstFile(domIdx, instIdx, file);
}
function _applyInstLoaded(domIdx, instIdx, name, content) {
  const lbl = document.getElementById(`dz-inst-lbl-${domIdx}-${instIdx}`);
  const dz  = document.getElementById(`dz-inst-${domIdx}-${instIdx}`);
  const rm  = document.getElementById(`dz-inst-rm-${domIdx}-${instIdx}`);
  const pre = document.getElementById(`dz-inst-pre-${domIdx}-${instIdx}`);
  if (lbl) lbl.innerHTML = `✓ ${esc(name)} <span style="font-size:10px;color:var(--accent);cursor:pointer;text-decoration:underline;text-underline-offset:2px;margin-left:6px" onclick="event.stopPropagation();togglePre('dz-inst-pre-${domIdx}-${instIdx}',this)">▾ view</span>`;
  if (dz)  dz.classList.add('dz-loaded');
  if (rm)  rm.style.display = 'inline-flex';
  if (pre) pre.textContent = content;
}
function loadInstFile(domIdx, instIdx, file) {
  const key = `${domIdx}-${instIdx}`;
  const reader = new FileReader();
  reader.onload = e => {
    instanceFiles.set(key, { name: file.name, content: e.target.result });
    _applyInstLoaded(domIdx, instIdx, file.name, e.target.result);
  };
  reader.readAsText(file);
}
function setInstContent(domIdx, instIdx, filename, content) {
  if (!filename || !content) return;
  instanceFiles.set(`${domIdx}-${instIdx}`, { name: filename, content });
  _applyInstLoaded(domIdx, instIdx, filename, content);
}

function removeInstFile(domIdx, instIdx) {
  instanceFiles.delete(`${domIdx}-${instIdx}`);
  const lbl = document.getElementById(`dz-inst-lbl-${domIdx}-${instIdx}`);
  const dz  = document.getElementById(`dz-inst-${domIdx}-${instIdx}`);
  const rm  = document.getElementById(`dz-inst-rm-${domIdx}-${instIdx}`);
  const inp = document.getElementById(`df-inst-${domIdx}-${instIdx}`);
  const pre = document.getElementById(`dz-inst-pre-${domIdx}-${instIdx}`);
  if (lbl) lbl.innerHTML = 'Drop .pddl or browse';
  if (dz)  dz.classList.remove('dz-loaded');
  if (rm)  rm.style.display = 'none';
  if (inp) inp.value = '';
  if (pre) { pre.textContent = ''; pre.style.display = 'none'; }
}

// ── Instances (per domain) ────────────────────────────────────────────────────
let ii = 0;
function addInstance(domIdx) {
  const idx = ii++;
  const container = document.getElementById(`inst-list-${domIdx}`);
  const d = document.createElement('div');
  d.id = `inst-${domIdx}-${idx}`;
  d.style.cssText = 'border:1px solid #1a2800;border-radius:4px;padding:8px;margin-bottom:6px';
  d.innerHTML = `
    <div style="display:grid;grid-template-columns:2fr .7fr .7fr 2fr 1fr 28px;gap:6px;align-items:center;margin-bottom:6px">
      <input class="fi" id="in-name-${domIdx}-${idx}" type="text" placeholder="instance name" style="font-size:12px;padding:6px 8px" />
      <input class="fi" id="in-n-${domIdx}-${idx}"    type="text" placeholder="n"            style="font-size:12px;padding:6px 8px" />
      <input class="fi" id="in-k-${domIdx}-${idx}"    type="text" placeholder="opt. cost"    style="font-size:12px;padding:6px 8px" />
      <select class="fs" id="in-st-${domIdx}-${idx}" style="font-size:12px;padding:5px 8px">
        <option value="unknown">unknown</option>
        <option value="solved">solved</option>
        <option value="optimal">optimal</option>
        <option value="satisficing">satisficing</option>
        <option value="unsolvable">unsolvable</option>
        <option value="open">open</option>
      </select>
      <input class="fi" id="in-src-${domIdx}-${idx}" type="text" placeholder="source"        style="font-size:12px;padding:6px 8px" />
      <button type="button" class="rm-btn" onclick="document.getElementById('inst-${domIdx}-${idx}').remove()">×</button>
    </div>
    <textarea class="ft" id="in-desc-${domIdx}-${idx}" rows="2" placeholder="Briefly describe this instance…" style="font-size:11px;margin-bottom:6px"></textarea>
    <div class="drop-zone drop-zone-sm" id="dz-inst-${domIdx}-${idx}"
         ondragover="event.preventDefault();this.classList.add('dz-over')"
         ondragleave="this.classList.remove('dz-over')"
         ondrop="handleInstDrop(event,${domIdx},${idx})"
         onclick="document.getElementById('df-inst-${domIdx}-${idx}').click()">
      <span id="dz-inst-lbl-${domIdx}-${idx}">Drop .pddl or browse</span>
    </div>
    <input type="file" id="df-inst-${domIdx}-${idx}" accept=".pddl" style="display:none" onchange="handleInstFile(event,${domIdx},${idx})" />
    <button type="button" class="dz-rm" id="dz-inst-rm-${domIdx}-${idx}" onclick="removeInstFile(${domIdx},${idx})">× Remove file</button>
    <pre id="dz-inst-pre-${domIdx}-${idx}" style="display:none;margin-top:6px;max-height:180px;overflow:auto;font-size:11px;line-height:1.5;background:#060c00;border:1px solid var(--border);border-radius:4px;padding:10px;color:var(--text);white-space:pre"></pre>`;
  container.appendChild(d);
}

function getInstances(domIdx) {
  const container = document.getElementById(`inst-list-${domIdx}`);
  if (!container) return [];
  return [...container.children].map(r => {
    const idx = r.id.replace(`inst-${domIdx}-`, '');
    return {
      name:   val(`in-name-${domIdx}-${idx}`),
      n:      val(`in-n-${domIdx}-${idx}`)   || '—',
      k:      val(`in-k-${domIdx}-${idx}`)   || '—',
      status: val(`in-st-${domIdx}-${idx}`)  || 'unknown',
      source: val(`in-src-${domIdx}-${idx}`),
      file:        (() => { const iFile = instanceFiles.get(`${domIdx}-${idx}`); if (iFile) return `instances/${iFile.name}`; const n = val(`in-name-${domIdx}-${idx}`); return n ? `instances/${slugify(n)}.pddl` : ''; })(),
      description: document.getElementById(`in-desc-${domIdx}-${idx}`)?.value?.trim() || '',
      _fileKey: `${domIdx}-${idx}`,
    };
  }).filter(r => r.name);
}

function getDomains() {
  return [...document.querySelectorAll('#domains-list .entry-card')].map(r => {
    const i = r.id.replace('dom-', '');
    const langSel = document.getElementById(`dl-${i}`).value;
    const lang = langSel === 'Other' ? (val(`dl-other-${i}`) || 'Other') : langSel;
    const title = val(`dt-${i}`);
    return { key: slugify(title), title, lang, _idx: parseInt(i),
             src: val(`ds-${i}`), notes: val(`dn-${i}`), ss: val(`dss-${i}`),
             types: getTypes(i), goal: val(`dg-${i}`),
             predicates: getPredicates(i), actions: getActions(i),
             instances: getInstances(i) };
  }).filter(d => d.title);
}

// ── Types (per domain) ───────────────────────────────────────────────────────
let tyi = 0;
function addType(domIdx) {
  const idx = tyi++;
  const container = document.getElementById(`type-list-${domIdx}`);
  const d = document.createElement('div');
  d.className = 'drow'; d.id = `ty-${domIdx}-${idx}`;
  d.innerHTML = `
