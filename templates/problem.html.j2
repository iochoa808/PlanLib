<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{ problem.id }} – {{ problem.title }} | Planning Problem Library</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,700;1,9..144,300&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="{{ base }}static/index.css" />
<link rel="stylesheet" href="{{ base }}static/planlib.css" />
</head>
<body>

<nav class="topbar">
  <div class="topbar-left">
    <a class="topbar-logo" href="{{ base }}">PlanLib</a>
    <span class="topbar-sep">›</span>
    <a href="{{ base }}problems/">Problems</a>
    <span class="topbar-sep">›</span>
    <span class="topbar-crumb">{{ problem.id }} – {{ problem.title }}</span>
  </div>
  <div class="topbar-nav">
    <a href="{{ base }}problems/">Problems</a>
    <a href="{{ base }}languages/">Languages</a>
    <a href="{{ base }}ipc/">IPC</a>
    <a href="{{ base }}tags/">Tags</a>
    <a href="{{ base }}#about">About</a>
    <a href="{{ base }}contribute/">Contribute</a>
    <a href="https://github.com/planlib/planlib" target="_blank" rel="noopener">GitHub ↗</a>
  </div>
</nav>

<div class="hero">
  <div>
    <div class="prob-id">{{ problem.id }}</div>
    <div class="prob-title">{{ problem.title }}</div>
    <div class="prob-subtitle">{{ problem.subtitle }}</div>
    <div class="badge-row">
      {% for tag in problem.tags %}<a class="badge" href="{{ base }}tags/{{ tag | lower | replace(' ', '-') }}/">{{ tag }}</a>{% endfor %}
      {% for f in problem.languages %}<a class="badge blue" href="{{ base }}languages/{{ f | lower | replace(' ', '-') | replace('.', '') }}/">{{ f }}</a>{% endfor %}
      {% if problem.ipc_editions is defined %}{% for ed in problem.ipc_editions %}<a class="badge neutral" href="{{ base }}ipc/{{ ed | lower | replace(' ', '-') }}/">{{ ed }}</a>{% endfor %}{% endif %}
    </div>
  </div>
  <div class="meta-box">
    <table>{% for key, value in problem.meta.items() %}{% if value %}<tr><td>{{ key }}</td><td>{{ value }}</td></tr>{% endif %}{% endfor %}</table>
  </div>
</div>

<div class="tabs">
  <div class="tab active" onclick="show('description',this)">Description</div>
  <div class="tab" onclick="show('domains',this)">Domains</div>
  <div class="tab" onclick="show('references',this)">References</div>
</div>

{# ═══════════════════════════════════════════════════════════════ DESCRIPTION #}
<div id="description" class="panel active">

  {# Sections: description, history, variants, etc. #}
  {% for section in problem.description.sections %}
  <h2>{{ section.heading }}</h2>
  {% if section.variants is defined %}
  <div class="variant-row">
    {% for v in section.variants %}
    {% if v.href %}
      {% if v.href[:8] == '#domain-' %}
      <a class="variant-chip" href="javascript:void(0)" onclick="jumpToDomain('{{ v.href[8:] }}')">{{ v.label }}</a>
      {% else %}
      <a class="variant-chip" href="{{ v.href }}" target="_blank" rel="noopener">{{ v.label }}</a>
      {% endif %}
    {% elif not v.href %}
    <a class="variant-chip variant-chip-stub" href="{{ base }}problems/not-yet/?name={{ v.label | urlencode }}">{{ v.label }}</a>
    {% else %}
    <span class="variant-chip">{{ v.label }}</span>
    {% endif %}
    {% endfor %}
  </div>
  {% if section.body %}<p style="margin-top:8px">{{ section.body | md_body }}</p>{% endif %}
  {% else %}
  {% if section.body %}{{ section.body | md_body }}{% endif %}
  {% endif %}
  {% endfor %}

  {# Complexity — pulled from formal #}
  {% if problem.formal is defined and problem.formal.complexity is defined %}
  <h2>Complexity</h2>
  <table class="complexity-table">
    <thead><tr><th>Problem</th><th>Qualifier</th><th>Class</th></tr></thead>
    <tbody>
      {% for row in problem.formal.complexity %}
      <tr>
        <td>{{ row.problem }}</td>
        <td class="complexity-qualifier">{{ row.qualifier if row.qualifier else '—' }}</td>
        <td><span class="complexity-badge complexity-badge--{{ row.class }}">{{ row.result }}</span></td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  {% endif %}

  {# Key results #}
  {% if problem.results is defined and problem.results.mathematical is defined %}
  {% for r in problem.results.mathematical %}
  {% if loop.first %}<h2>Key Results</h2>{% endif %}
  <p>
    <strong style="color:#fff">{{ r.statement }}{% if r.ref %} <a class="ref-link" onclick="jumpToRef('{{ r.ref }}')">[{{ r.ref }}]</a>{% endif %}</strong><br>
    {{ r.detail }}
  </p>
  {% endfor %}
  {% endif %}

</div>

{# ═══════════════════════════════════════════════════════════════ DOMAINS #}
<div id="domains" class="panel">

  {% for domain in problem.domains.entries %}
  {% set card_id = 'domain-' ~ domain.key %}

  {# Collect instances for this domain #}
  {% set ns = namespace(domain_instances=[]) %}
  {% for row in problem.instances.rows %}
    {% if row.domain == domain.key %}
      {% set ns.domain_instances = ns.domain_instances + [row] %}
    {% endif %}
  {% endfor %}

  <div class="domain-card" id="{{ card_id }}">

    {# ── Card header ── #}
    <div class="domain-card-header" id="header-{{ card_id }}" onclick="toggleCard('{{ card_id }}')">
      <div style="display:flex;align-items:center;gap:10px;flex-wrap:wrap">
        <span class="domain-card-title">{{ domain.title }}</span>
      </div>
      <div class="domain-card-meta">
        <span class="lang-badge">{{ domain.language }}</span>
        {% if domain._content is defined and domain._content %}
        <button class="file-link" onclick="event.stopPropagation(); downloadDomainZip({{ loop.index0 }})">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M5 1v5M2.5 4.5L5 7l2.5-2.5M1 8.5h8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
          zip
        </button>
        {% endif %}
        <span class="chevron" id="chevron-{{ card_id }}">▾</span>
      </div>
    </div>

    {# ── Card body ── #}
    <div class="domain-card-body" id="body-{{ card_id }}">

      {# Notes #}
      {% if domain.notes %}<div class="domain-notes">{{ domain.notes }}</div>{% endif %}

      {# Source #}
      {% if domain.source_ref is defined and domain.source_ref %}
      <div class="domain-source">Source: <a class="ref-link" onclick="jumpToRef('{{ domain.source_ref }}')">[{{ domain.source_ref }}]</a></div>
      {% endif %}

      {% set vp = domain.viewpoint if (domain.viewpoint is defined) else problem.formal %}
      {% if vp is defined %}

      {# State Space / Types / Objects #}
      {% if vp.state_space or vp.types or vp.objects %}
      <div class="domain-section">
        {% if vp.state_space %}<h3>State Space</h3>{{ vp.state_space | md_body }}{% endif %}
        {% if vp.types %}
        <h3>Types</h3>
        <div class="pred-grid">
          {% for t in vp.types %}
          <div class="pred-item"><div class="pred-name">{{ t.name }}</div><div class="pred-desc">→ {{ t.parent }}</div></div>
          {% endfor %}
        </div>
        {% endif %}
        {% if vp.objects %}<h3>Objects</h3>{{ vp.objects | md_body }}{% endif %}
      </div>
      {% endif %}

      {# Predicates #}
      {% if vp.predicates is defined %}
      <div class="domain-section">
        <h3>Predicates</h3>
        <div class="pred-grid">
          {% for pred in vp.predicates %}
          <div class="pred-item"><div class="pred-name">{{ pred.name }}</div><div class="pred-desc">{{ pred.desc }}</div></div>
          {% endfor %}
        </div>
      </div>
      {% endif %}

      {# Actions + Goal #}
      {% if vp.actions is defined %}
      <div class="domain-section">
        <h3>Actions</h3>
        {% for action in vp.actions %}
        <div class="code-wrap">
          <div class="code-header"><div class="code-header-left"><span class="fname">{{ action.name }}</span><span style="color:var(--muted)">{{ action.desc }}</span></div></div>
          <pre class="pddl">{{ action.schema | e }}</pre>
        </div>
        {% endfor %}
        {% if vp.goal %}<h3>Goal</h3>{{ vp.goal | md_body }}{% endif %}
      </div>
      {% endif %}

      {# PDDL source #}
      {% if domain._content is defined and domain._content %}
      <div class="domain-section">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
          <h3 style="margin:0">PDDL Source</h3>
          <button class="file-link" onclick="downloadText('{{ domain.file.split('/')[-1] }}', domainContents[{{ loop.index0 }}])">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M5 1v5M2.5 4.5L5 7l2.5-2.5M1 8.5h8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
            Domain
          </button>
        </div>
        <pre class="pddl">{{ domain._content | e }}</pre>
      </div>
      {% endif %}

      {% endif %}{# end viewpoint #}

      {# Instances for this domain #}
      {% if ns.domain_instances %}
      <div class="inst-list">
        <h3>Instances</h3>
        {% if problem.instances.description %}<p style="font-size:12px;color:var(--muted);margin-bottom:10px">{{ problem.instances.description }}</p>{% endif %}
        <table class="inst">
          <thead>
            <tr><th>#</th><th>Name</th><th>n</th><th>opt. cost</th><th>Status</th><th>Source</th><th>File</th></tr>
          </thead>
          <tbody>
            {%- set global_idx = problem.instances.rows | map(attribute='id') | list %}
            {% for row in ns.domain_instances %}
            {%- set has_detail = row.description is defined and row.description %}
            <tr id="inst-{{ row.id }}"{% if has_detail %} class="inst-row" onclick="toggleInstRow('{{ row.id }}')" style="cursor:pointer"{% endif %}>
              <td>{{ row.id }}{% if has_detail %} <span class="inst-row-chev" id="inst-chev-{{ row.id }}">▾</span>{% endif %}</td>
              <td>{{ row.name }}</td>
              <td>{{ row.n if row.n is not none else '—' }}</td>
              <td class="opt">{{ row.optimal if row.optimal is not none else '—' }}</td>
              <td class="status">{{ row.status }}</td>
              <td>{% if row.source_ref %}<a class="ref-link" onclick="jumpToRef('{{ row.source_ref }}')">[{{ row.source_ref }}]</a>{% else %}—{% endif %}</td>
              <td>{% if row.file and row._content is defined and row._content %}<button class="file-link" onclick="event.stopPropagation();downloadText('{{ row.file.split('/')[-1] }}', instanceContents[{{ global_idx.index(row.id) }}])"><svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M5 1v5M2.5 4.5L5 7l2.5-2.5M1 8.5h8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>.pddl</button>{% else %}<span style="color:var(--muted)">—</span>{% endif %}</td>
            </tr>
            {% if has_detail %}
            <tr id="inst-det-{{ row.id }}" style="display:none">
              <td colspan="7" style="padding:0">
                <div style="padding:10px 16px;background:#0a0f00;border-top:1px solid #1a2800">
                  <p style="font-size:12px;color:#aaa;margin:0;line-height:1.7">{{ row.description }}</p>
                </div>
              </td>
            </tr>
            {% endif %}
            {% endfor %}
          </tbody>
        </table>
        {% if problem.instances.generator_note %}
        {% for para in problem.instances.generator_note.split('\n\n') %}<p style="font-size:12px;color:var(--muted);margin-top:8px">{{ para }}</p>{% endfor %}
        {% endif %}
      </div>
      {% endif %}

    </div>{# end body #}
  </div>{# end card #}
  {% endfor %}

</div>

{# ═══════════════════════════════════════════════════════════════ REFERENCES #}
<div id="references" class="panel">
  <h2>References</h2>
  {% for ref in problem.references %}
  <div class="ref" id="ref-{{ ref.key }}">
    <div class="ref-key">[{{ ref.key }}]</div>
    <div class="ref-title">
      {% if ref.url is defined and ref.url %}
      <a href="{{ ref.url }}" target="_blank" rel="noopener" style="color:#fff;border-bottom:1px solid #333;padding-bottom:1px;transition:border-color .15s" onmouseover="this.style.borderColor='#fff'" onmouseout="this.style.borderColor='#333'">{{ ref.title }}</a>
      {% else %}{{ ref.title }}{% endif %}
    </div>
    <div class="ref-authors">{{ ref.authors }}</div>
    <div class="ref-venue">{{ ref.venue }}</div>
    {% if ref.note is defined %}<div class="ref-note">{{ ref.note }}</div>{% endif %}
  </div>
  {% endfor %}
  <h2>BibTeX</h2>
  <div class="bibtex-block">{{ problem.bibtex }}</div>
</div>

{# Per-page data: PDDL file contents inlined for the download buttons #}
<script>
const domainContents = [
  {% for domain in problem.domains.entries %}
  {{ domain._content | tojson if (domain._content is defined and domain._content) else '""' }}{% if not loop.last %},{% endif %}

  {% endfor %}
];
const instanceContents = [
  {% for row in problem.instances.rows %}
  {{ row._content | tojson if (row._content is defined and row._content) else '""' }}{% if not loop.last %},{% endif %}

  {% endfor %}
];
{%- set _gidx = problem.instances.rows | map(attribute='id') | list %}
const domainData = [
  {% for domain in problem.domains.entries %}
  { file: {{ (domain.file.split('/')[-1]) | tojson if domain.file is defined else '""' }},
    instances: [{% for row in problem.instances.rows if row.domain == domain.key and (row._content is defined and row._content) and row.file %}{ idx: {{ _gidx.index(row.id) }}, file: {{ (row.file.split('/')[-1]) | tojson }} }{% if not loop.last %}, {% endif %}{% endfor %}] }{% if not loop.last %},{% endif %}

  {% endfor %}
];
</script>
<script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js"></script>
<script>
function toggleInstRow(id) {
  const det  = document.getElementById('inst-det-' + id);
  const chev = document.getElementById('inst-chev-' + id);
  if (!det) return;
  const open = det.style.display === 'none';
  det.style.display = open ? '' : 'none';
  if (chev) chev.style.transform = open ? 'rotate(180deg)' : '';
}
async function downloadDomainZip(idx) {
  const d = domainData[idx];
  const zip = new JSZip();
  if (domainContents[idx]) zip.file(d.file || 'domain.pddl', domainContents[idx]);
  d.instances.forEach(inst => {
    if (instanceContents[inst.idx]) zip.file(inst.file, instanceContents[inst.idx]);
  });
  if (!Object.keys(zip.files).length) return;
  const blob = await zip.generateAsync({ type: 'blob' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = (d.file || 'domain').replace(/\.[^.]+$/, '') + '.zip';
  a.click();
  URL.revokeObjectURL(a.href);
}
</script>
<script>
(function(){
  const KW=new Set(['define','domain','problem','and','or','not','forall','exists','when','imply','either','minimize','maximize','always','sometime','at-most-once','sometime-after','sometime-before','hold-during','hold-after','is-violated','total-cost']);
  const SEC=new Set([':requirements',':types',':constants',':predicates',':functions',':action',':durative-action',':derived',':axiom',':init',':goal',':objects',':metric',':duration',':precondition',':effect',':parameters',':condition',':constraints',':strips',':typing',':equality',':negative-preconditions',':disjunctive-preconditions',':conditional-effects',':numeric-fluents',':action-costs',':durative-actions',':timed-initial-literals',':preferences',':quantified-preconditions',':existential-preconditions',':universal-preconditions',':adl',':fluents',':continuous-effects',':open-world',':true-negation']);
  function e(s){return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
  function highlight(src){
    let out='',i=0;
    while(i<src.length){
      if(src[i]===';'){
        let j=src.indexOf('\n',i);if(j<0)j=src.length;
        out+=`<span class="ph-c">${e(src.slice(i,j))}</span>`;i=j;continue;
      }
      if(src[i]==='?'){
        const m=src.slice(i).match(/^\?[\w-]*/);
        if(m){out+=`<span class="ph-v">${e(m[0])}</span>`;i+=m[0].length;continue;}
      }
      if(src[i]===':'){
        const m=src.slice(i).match(/^:[\w-]*/);
        if(m){out+=`<span class="${SEC.has(m[0])?'ph-s':'ph-s'}">${e(m[0])}</span>`;i+=m[0].length;continue;}
      }
      if(/\d/.test(src[i])||(src[i]==='-'&&/\d/.test(src[i+1]||''))){
        const m=src.slice(i).match(/^-?\d+(\.\d+)?/);
        if(m){out+=`<span class="ph-n">${e(m[0])}</span>`;i+=m[0].length;continue;}
      }
      if(/[a-zA-Z_]/.test(src[i])){
        const m=src.slice(i).match(/^[\w-]*/);
        if(m){out+=KW.has(m[0])?`<span class="ph-k">${e(m[0])}</span>`:e(m[0]);i+=m[0].length;continue;}
      }
      if(src[i]==='('||src[i]===')'){out+=`<span class="ph-p">${src[i]}</span>`;i++;continue;}
      out+=e(src[i]);i++;
    }
    return out;
  }
  document.querySelectorAll('pre.pddl').forEach(pre=>{pre.innerHTML=highlight(pre.textContent);});
})();
</script>
<script src="{{ base }}static/planlib.js"></script>

<footer class="footer">
  <span>PlanLib — AI Planning Problem Library</span>
  <span><a href="https://github.com/planlib/planlib" target="_blank" rel="noopener">GitHub</a> · <a href="#">Cite</a> · <a href="#">Contact</a></span>
</footer>
</body>
</html>
